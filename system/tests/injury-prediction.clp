; 8/4/2026 - Claude - Prompt: Generate unit tests and test cases for the injury-prediction module based on exisiting unit tests
(deffunction check-consultation-required (?expects-recommendation ?expected-explanation-count)
    (bind ?facts (find-all-facts ((?f consultation-required)) TRUE))
    (if (= (length$ ?facts) 0)
      then (printout t "Error: No consultation-required fact found" crlf)
    else
        (bind ?cf (get-cf (nth$ 1 ?facts)))
        (bind ?explanations (fact-slot-value (nth$ 1 (find-all-facts ((?e injury-explanation)) TRUE)) explanations))
        (bind ?actual-explanation-count (length$ ?explanations))
        (if (eq ?expects-recommendation yes)
          then (if (not (any-factp ((?r recommendation)) TRUE))
              then (printout t "Error: Expected recommendation but none found (CF: " ?cf ")" crlf)
          else (if (neq ?actual-explanation-count ?expected-explanation-count)
                 then (printout t "Error: Expected " ?expected-explanation-count " explanation(s) but found " ?actual-explanation-count " (CF: " ?cf ")" crlf)
                 else (printout t "OK: Consultation recommended with " ?actual-explanation-count " explanation(s) (CF: " ?cf ")" crlf)))
          else (if (any-factp ((?r recommendation)) TRUE)
              then (printout t "Error: Did not expect recommendation but one was found (CF: " ?cf ")" crlf)
              else (if (neq ?actual-explanation-count ?expected-explanation-count)
                     then (printout t "Error: Expected " ?expected-explanation-count " explanation(s) but found " ?actual-explanation-count " (CF: " ?cf ")" crlf)
                     else (printout t "OK: No consultation required with " ?actual-explanation-count " explanation(s) (CF: " ?cf ")" crlf)))))
)

(deffunction run-test-case-injury-prediction (?age ?injury ?experience ?exercise-type ?expects-recommendation ?expected-explanation-count)
    (printout t "===========================================================================================================" crlf)
    (printout t "Test input: Age: " ?age ", Injury: " ?injury ", Experience: " ?experience ", Exercise type: " ?exercise-type crlf)
    (reset)
    (do-for-all-facts ((?ui user-input)) TRUE
        (modify ?ui (age ?age) (has-previous-injury ?injury) (experience ?experience) (exercise-type ?exercise-type)))
    (focus INJURY-PREDICTION)
    (run)
    (check-consultation-required ?expects-recommendation ?expected-explanation-count)
    (focus MAIN)
)

(deffunction test-injury-prediction ()
    (printout t "Testing injury prediction:" crlf)
    (run-test-case-injury-prediction 15 yes no free-weight yes 3)
    (run-test-case-injury-prediction 50 yes yes machine yes 2)
    (run-test-case-injury-prediction 30 yes no free-weight yes 2)
    (run-test-case-injury-prediction 40 no no free-weight yes 2)
    (run-test-case-injury-prediction 40 no no machine no 2)
    (run-test-case-injury-prediction 30 no yes machine no 0)
    (run-test-case-injury-prediction 22 no yes machine no 1)
)
